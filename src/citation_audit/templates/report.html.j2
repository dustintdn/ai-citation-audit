<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI Citation Audit — {{ brand }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      font-size: 14px;
      color: #1a1a1a;
      background: #f5f5f5;
      padding: 2rem;
    }

    .container { max-width: 960px; margin: 0 auto; }

    header { margin-bottom: 2rem; }
    header h1 { font-size: 1.5rem; font-weight: 600; }
    header p  { color: #555; margin-top: 0.25rem; }

    .meta {
      display: flex;
      gap: 2rem;
      margin-bottom: 2rem;
      padding: 1rem 1.25rem;
      background: #fff;
      border: 1px solid #e0e0e0;
      border-radius: 6px;
    }
    .meta dt { font-size: 0.75rem; color: #888; text-transform: uppercase; letter-spacing: 0.05em; }
    .meta dd { font-weight: 500; margin-top: 0.15rem; }

    h2 { font-size: 1rem; font-weight: 600; margin-bottom: 0.75rem; color: #333; }

    section { margin-bottom: 2.5rem; }

    table {
      width: 100%;
      border-collapse: collapse;
      background: #fff;
      border: 1px solid #e0e0e0;
      border-radius: 6px;
      overflow: hidden;
    }
    thead tr { background: #f0f0f0; }
    th {
      text-align: left;
      padding: 0.6rem 0.9rem;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #555;
      border-bottom: 1px solid #e0e0e0;
    }
    td {
      padding: 0.55rem 0.9rem;
      border-bottom: 1px solid #f0f0f0;
      vertical-align: middle;
    }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #fafafa; }

    .badge {
      display: inline-block;
      padding: 0.15rem 0.5rem;
      border-radius: 999px;
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .badge-positive  { background: #d1fae5; color: #065f46; }
    .badge-neutral   { background: #e5e7eb; color: #374151; }
    .badge-negative  { background: #fee2e2; color: #991b1b; }
    .badge-first     { background: #dbeafe; color: #1e40af; }
    .badge-top3      { background: #ede9fe; color: #5b21b6; }
    .badge-present   { background: #fef9c3; color: #854d0e; }
    .badge-absent    { background: #f3f4f6; color: #9ca3af; }
    .badge-switching { background: #fff7ed; color: #9a3412; }

    .row-switching td { color: #6b7280; font-style: italic; }

    .footnote {
      margin-top: 0.75rem;
      font-size: 0.75rem;
      color: #9ca3af;
    }

    .pct-bar {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .pct-bar-track {
      flex: 1;
      height: 6px;
      background: #e5e7eb;
      border-radius: 3px;
      overflow: hidden;
    }
    .pct-bar-fill {
      height: 100%;
      background: #3b82f6;
      border-radius: 3px;
    }
    .pct-label { font-size: 0.75rem; color: #555; min-width: 2.5rem; text-align: right; }

    footer {
      margin-top: 3rem;
      font-size: 0.75rem;
      color: #aaa;
      text-align: center;
    }
  </style>
</head>
<body>
<div class="container">

  <header>
    <h1>AI Citation Audit Report</h1>
    <p>How <strong>{{ brand }}</strong> is mentioned across LLM responses in <em>{{ industry }}</em></p>
  </header>

  <div class="meta">
    <div>
      <dl>
        <dt>Target Brand</dt>
        <dd>{{ brand }}</dd>
      </dl>
    </div>
    <div>
      <dl>
        <dt>Industry</dt>
        <dd>{{ industry }}</dd>
      </dl>
    </div>
    <div>
      <dl>
        <dt>Competitors Tracked</dt>
        <dd>{{ competitors | join(", ") if competitors else "—" }}</dd>
      </dl>
    </div>
    <div>
      <dl>
        <dt>Models Audited</dt>
        <dd>{{ models | join(", ") }}</dd>
      </dl>
    </div>
    <div>
      <dl>
        <dt>Generated</dt>
        <dd>{{ generated_at }}</dd>
      </dl>
    </div>
  </div>

  {# ── Per-model summary tables ─────────────────────────────────────────── #}
  {% for model in models %}
  <section>
    <h2>{{ model | title }}</h2>
    <table>
      <thead>
        <tr>
          <th>Brand</th>
          <th>Intent</th>
          <th>Mention Rate</th>
          <th>Avg Position</th>
          <th>Dominant Sentiment</th>
          <th>Citations</th>
        </tr>
      </thead>
      <tbody>
        {% for row in scores_by_model[model] %}
        <tr{% if row.intent.value == "switching" %} class="row-switching"{% endif %}>
          <td>{{ row.brand }}</td>
          <td>
            {% if row.intent.value == "switching" %}
              <span class="badge badge-switching">Switching ⚠</span>
            {% else %}
              {{ row.intent.value | replace("_", " ") | title }}
            {% endif %}
          </td>
          <td>
            <div class="pct-bar">
              <div class="pct-bar-track">
                <div class="pct-bar-fill" style="width: {{ (row.mention_rate * 100) | round | int }}%"></div>
              </div>
              <span class="pct-label">{{ (row.mention_rate * 100) | round | int }}%</span>
            </div>
          </td>
          <td>
            {% set pos = row.avg_position_label %}
            {% if pos == "FIRST" %}
              <span class="badge badge-first">First</span>
            {% elif pos == "TOP_3" %}
              <span class="badge badge-top3">Top 3</span>
            {% elif pos == "PRESENT" %}
              <span class="badge badge-present">Present</span>
            {% else %}
              <span class="badge badge-absent">Absent</span>
            {% endif %}
          </td>
          <td>
            {% set s = row.dominant_sentiment.value %}
            <span class="badge badge-{{ s }}">{{ s | title }}</span>
          </td>
          <td>{{ (row.citation_rate * 100) | round | int }}%</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </section>
  {% endfor %}

  <footer>
    Generated by ai-citation-audit &middot; {{ generated_at }}
  </footer>

</div>
</body>
</html>
